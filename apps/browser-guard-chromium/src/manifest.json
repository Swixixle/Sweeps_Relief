{
  "manifest_version": 3,
  "name": "Sweeps Relief Browser Guard",
  "version": "0.1.0",
  "description": "Local safe-paste and field-risk defense for high-risk sweeps / social-casino pages.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Sweeps Relief Guard",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
